# Get Sepolia ETH from https://sepoliafaucet.com
# Get a WalletConnect project ID from https://cloud.walletconnect.com
# Add your private key for demo wallet (optional; connect WalletConnect instead)

SEPOLIA_RPC_URL=https://rpc.sepolia.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
DEMO_PRIVATE_KEY=your_private_key_here
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Hardcoded receiver for NFC flow: tap any tag -> "Connection successful" -> send tokens to this address
HARDCODED_RECEIVER_ADDRESS=0xYourReceiverAddress
